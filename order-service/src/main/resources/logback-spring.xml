<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- DEV: colored human-readable console output -->
  <springProfile name="dev">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%cyan(%thread)] %yellow(%logger{36}) - %msg%n</pattern>
      </encoder>
    </appender>
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>
    <logger name="com.retailstore" level="DEBUG"/>
    <logger name="org.springframework.cloud.gateway" level="INFO"/>
    <logger name="reactor.netty" level="WARN"/>
  </springProfile>

  <!-- STAGE / PROD: structured JSON for CloudWatch log parsing -->
  <springProfile name="stage,prod">
    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <customFields>{"app":"${spring.application.name:-unknown}"}</customFields>
        <fieldNames>
          <timestamp>timestamp</timestamp>
          <message>message</message>
          <logger>logger</logger>
          <thread>thread</thread>
          <levelValue>[ignore]</levelValue>
        </fieldNames>
        <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
          <maxDepthPerCause>20</maxDepthPerCause>
          <shortenedClassNameLength>20</shortenedClassNameLength>
        </throwableConverter>
      </encoder>
    </appender>
    <root level="INFO">
      <appender-ref ref="JSON"/>
    </root>
    <logger name="com.retailstore" level="INFO"/>
    <logger name="org.springframework"  level="WARN"/>
    <logger name="reactor.netty"        level="WARN"/>
  </springProfile>

</configuration>
